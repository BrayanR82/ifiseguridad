<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 900" role="img" aria-labelledby="title desc">
  <title id="title">Configuracion NVR DVR</title>
  <desc id="desc">Grabador y pantallas de canal</desc>
  <defs><linearGradient id="bg" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#edf4ff"/><stop offset="100%" stop-color="#fbfdff"/></linearGradient></defs>
  <rect width="1200" height="900" fill="url(#bg)"/>
  <rect x="150" y="190" width="900" height="500" rx="32" fill="#ffffff" stroke="#d7e5ff"/>
  <rect x="210" y="270" width="280" height="180" rx="16" fill="#e5efff"/>
  <rect x="520" y="270" width="280" height="180" rx="16" fill="#e5efff"/>
  <rect x="830" y="270" width="160" height="180" rx="16" fill="#e5efff"/>
  <rect x="240" y="510" width="720" height="90" rx="20" fill="#173b87" opacity="0.9"/>
  <circle cx="285" cy="555" r="12" fill="#7cc27d"/>
  <circle cx="330" cy="555" r="12" fill="#e2cf68"/>
  <circle cx="375" cy="555" r="12" fill="#d98080"/>
  <text x="120" y="120" font-size="54" font-family="Inter, Arial, sans-serif" fill="#173b87">Configuracion NVR y DVR</text>
</svg>
