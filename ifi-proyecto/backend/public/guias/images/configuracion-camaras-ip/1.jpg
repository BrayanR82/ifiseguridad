<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 900" role="img" aria-labelledby="title desc">
  <title id="title">Configuracion camaras IP</title>
  <desc id="desc">Camara con panel de red y monitoreo</desc>
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#eef4ff"/>
      <stop offset="100%" stop-color="#f9fbff"/>
    </linearGradient>
  </defs>
  <rect width="1200" height="900" fill="url(#bg)"/>
  <rect x="120" y="190" width="960" height="520" rx="34" fill="#ffffff" stroke="#d8e4ff"/>
  <circle cx="370" cy="450" r="110" fill="#dbe9ff"/>
  <circle cx="370" cy="450" r="54" fill="#ffffff" stroke="#8cb0f5" stroke-width="10"/>
  <path d="M510 360h430M510 450h320M510 540h240" stroke="#2b4c97" stroke-width="22" stroke-linecap="round"/>
  <text x="120" y="120" font-size="54" font-family="Inter, Arial, sans-serif" fill="#173b87">Configuracion de camaras IP</text>
</svg>
