<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 900" role="img" aria-labelledby="title desc">
  <title id="title">GitLab Ubuntu Server</title>
  <desc id="desc">Repositorio con ramas y servidor Ubuntu</desc>
