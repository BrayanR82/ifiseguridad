  <rect width="1200" height="900" fill="url(#bg)"/>
  <rect x="170" y="220" width="440" height="470" rx="24" fill="#ffffff" stroke="#d8e5ff"/>
  <path d="M240 320h300M240 400h250M240 480h280" stroke="#2b4c97" stroke-width="20" stroke-linecap="round"/>
